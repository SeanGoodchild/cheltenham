# Frontend
# Local dev: point to Bun API
VITE_API_BASE_URL=http://localhost:3001
# Production: set this in Vercel to your deployed backend URL if API is not hosted on the same domain.

# Bun server
PORT=3001
APP_ORIGIN=http://localhost:5173

# Firebase project config used by server-side Firestore access
# Optional but recommended for server-side admin access:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_PROJECT_ID=rocketmill-octane
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=
